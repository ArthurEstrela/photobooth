# === DATABASE (Postgres) ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/photobooth?schema=public"
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=photobooth

# === REDIS (Queue Management) ===
REDIS_URL="redis://localhost:6379"

# === MERCADO PAGO (Payments) ===
MP_ACCESS_TOKEN="APP_USR-..."
MP_WEBHOOK_SECRET="your_secret_here"
# Email do pagador enviado à API do MP (PIX anônimo de totem)
MP_PAYER_EMAIL="cliente@seuphotobooth.com.br"

# === AWS S3 (Photo Storage) ===
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="your_secret_here"
AWS_REGION="sa-east-1"
AWS_S3_BUCKET="photobooth-storage"
AWS_CLOUDFRONT_DOMAIN="d12345abcdef.cloudfront.net"

# === CLERK (Authentication) ===
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."

# === WEBSOCKETS & API ===
PORT=3000
API_URL="http://localhost:3000"
WS_URL="ws://localhost:3000"

# === SECURITY ===
JWT_SECRET="your_super_secret_jwt_key"
